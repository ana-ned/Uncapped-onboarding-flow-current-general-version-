{
  "framework": null,
  "buildCommand": "true",
  "installCommand": "true",
  "outputDirectory": ".",
  "redirects": [
    { "source": "/", "destination": "/prototypes/registration", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/((?!static/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    }
  ]
}
